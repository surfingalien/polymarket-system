# ============================================================
# Polymarket-Kalshi AI Bot — Environment Configuration
# Copy to .env and fill in your credentials
# ============================================================

# ---- Global ------------------------------------------------
MOCK_MODE=true             # true = paper trading; false = live (DANGEROUS)

# ---- Anthropic / Claude ------------------------------------
ANTHROPIC_API_KEY=sk-ant-...

# ---- Polymarket CLOB V2 ------------------------------------
POLY_PRIVATE_KEY=0x...                          # EOA or deposit wallet private key
POLY_API_KEY=                                   # From https://clob.polymarket.com
POLY_API_SECRET=
POLY_API_PASSPHRASE=
POLY_CHAIN_ID=137                               # 137=Polygon mainnet, 80002=Amoy testnet
POLY_CLOB_HOST=https://clob.polymarket.com
POLY_GAMMA_HOST=https://gamma-api.polymarket.com

# ---- Kalshi ------------------------------------------------
KALSHI_API_KEY_ID=                              # From https://kalshi.com/profile/api
KALSHI_PRIVATE_KEY_PATH=keys/kalshi_private.pem
KALSHI_DEMO_MODE=true                           # true = demo.kalshi.co
KALSHI_API_HOST=https://trading-api.kalshi.com

# ---- Risk Management ---------------------------------------
RISK_MAX_POSITION_SIZE_USD=50
RISK_MAX_PORTFOLIO_EXPOSURE_USD=500
RISK_DAILY_LOSS_LIMIT_USD=100
RISK_STOP_LOSS_PCT=0.30
RISK_TAKE_PROFIT_PCT=0.80
RISK_MIN_EDGE_PCT=0.05
RISK_MAX_KELLY_FRACTION=0.25
RISK_MIN_CONFIDENCE_SCORE=0.65

# ---- News / Research ---------------------------------------
NEWS_TAVILY_API_KEY=tvly-...
NEWS_NEWSAPI_KEY=

# ---- Bot ---------------------------------------------------
BOT_CYCLE_INTERVAL_SECONDS=60
BOT_LOG_LEVEL=INFO
BOT_ENABLE_ARBITRAGE=true
BOT_ENABLE_POLYMARKET=true
BOT_ENABLE_KALSHI=true
BOT_ARBITRAGE_MIN_SPREAD_PCT=0.03
